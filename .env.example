# Скопируй в .env и заполни своими данными тестового аккаунта.
# .env в git НЕ коммитим (см. .gitignore).

# Базовый адрес YClients
BASE_URL=https://yclients.com

# ID филиала (взят из htmls/clients_base.html: /clients/1971030/base/).
# Поменяй на свой, если филиал другой.
SALON_ID=1971030

# Опциональная защита от работы в неверном YClients-аккаунте.
# REQUIRED: если задано, этот текст должен быть виден в кабинете.
# FORBIDDEN: если задано и этот текст виден, строки из таблицы не обрабатываются.
YCLIENTS_REQUIRED_ACCOUNT_TEXT=
YCLIENTS_FORBIDDEN_ACCOUNT_TEXT=

# Тестовые данные для одного прогона
TEST_NAME=Клиент Тест
TEST_PHONE=8005553535
TEST_PUSH_TEXT=Тест системы пушей

# headless=false — окно браузера видно (нужно для первого ручного логина + 2FA).
# Поставь true только когда сессия уже сохранена в профиле и логин не нужен.
HEADLESS=false

# DRY_RUN=true — пройти весь сценарий, ввести текст push, но НЕ нажимать «Отправить».
# Удобно, пока проверяем селекторы и не хотим реально слать пуши. Для боевой отправки — false.
DRY_RUN=true

# --- Google Sheets ---
# Путь к JSON-ключу СЕРВИС-АККАУНТА (не client_secret.json!). См. инструкцию по созданию.
GOOGLE_CREDENTIALS=service_account.json
# Просто вставь ссылку на свою таблицу целиком — ID скрипт вытащит сам.
SHEET_URL=https://docs.google.com/spreadsheets/d/XXXXXXXXXXXX/edit
# Название листа (вкладки). Пусто = первый лист.
WORKSHEET=

# Период опроса таблицы воркером (run.py), в секундах.
POLL_INTERVAL=60
